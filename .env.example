# Required
ANTHROPIC_API_KEY=sk-ant-...

# Discord (if enabled)
DISCORD_BOT_TOKEN=

# Slack (if enabled)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Optional
WARSCLAW_POLLING_INTERVAL=2000
WARSCLAW_IPC_INTERVAL=1000
WARSCLAW_MAX_CONTAINERS=5
WARSCLAW_MAX_RETRIES=5
WARSCLAW_TIMEZONE=Asia/Tokyo
WARSCLAW_DOCKER_IMAGE=warsclaw-agent
WARSCLAW_DATA_DIR=./data
WARSCLAW_GROUPS_DIR=./groups
WARSCLAW_ASSISTANT_NAME=WarsClaw
WARSCLAW_WORKSPACE_DIR=./workspace-repo
WARSCLAW_LOG_LEVEL=info

# Allowlist (comma-separated, empty = allow all)
# WARSCLAW_ALLOWED_SENDERS=U12345678,U87654321
# WARSCLAW_ALLOWED_CHANNELS=slack_C12345678,discord_123456789
