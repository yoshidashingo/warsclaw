# Required
ANTHROPIC_API_KEY=sk-ant-...

# Discord (if enabled)
DISCORD_BOT_TOKEN=

# Slack (if enabled)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Optional
MYCLAW_POLLING_INTERVAL=2000
MYCLAW_IPC_INTERVAL=1000
MYCLAW_MAX_CONTAINERS=5
MYCLAW_MAX_RETRIES=5
MYCLAW_TIMEZONE=Asia/Tokyo
MYCLAW_DOCKER_IMAGE=myclaw-agent
MYCLAW_DATA_DIR=./data
MYCLAW_GROUPS_DIR=./groups
MYCLAW_ASSISTANT_NAME=MyClaw
MYCLAW_LOG_LEVEL=info
